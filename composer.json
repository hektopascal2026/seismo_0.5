{
    "name": "hektopascal/seismo",
    "description": "Seismo 0.5 — legislation / feed monitor",
    "require": {
        "php": ">=8.1",
        "easyrdf/easyrdf": "^1.1",
        "simplepie/simplepie": "^1.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Seismo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Seismo\\Tests\\": "tests/"
        }
    }
}
